{
  "name": "Amazon Login Automate",
  "version": "1.1",
  "description": "Automated re-login and dual-method OTP verification for Amazon Hiring portals. Fetch OTPs via GAS API or directly from a Gmail tab.",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://auth.hiring.amazon.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "./assets/icons/16.png",
    "32": "./assets/icons/32.png",
    "48": "./assets/icons/48.png",
    "64": "./assets/icons/64.png",
    "128": "./assets/icons/128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://auth.hiring.amazon.com/*",
    "https://mail.google.com/*"
  ]
}